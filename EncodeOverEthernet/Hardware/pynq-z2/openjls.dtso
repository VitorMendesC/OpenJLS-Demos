// OpenJLS EncodeOverEthernet demo — PYNQ-Z2 device tree overlay.
//
// Matches the block design address map:
//   0x4000_0000  openjls_axis_regs register bank (4K)
//   0x4040_0000  AXI DMA registers (64K)
//
// Two things about the stock PYNQ image shaped this overlay:
//
//  * PYNQ declares its PL `generic-uio` nodes at the device-tree *root*,
//    not under /amba. On this kernel, overlay-added children of /amba are
//    never instantiated as platform devices (they appear in the live tree
//    but no /dev/uio* is created), so our nodes must go at the root too.
//
//  * PYNQ pre-declares a whole-PL UIO node, `fabric@40000000` (0x4000_0000,
//    64K), which overlaps our register bank. It is harmless: UIO maps
//    memory with ioremap but does not request_mem_region, so two UIO
//    devices can cover the same window without conflict, and the server
//    selects its device by name ("openjls"/"dma"), ignoring `fabric`.
//    (Because it maps without reserving, `fabric` is also invisible to
//    `grep /proc/iomem` — check /sys/bus/platform/drivers/uio_pdrv_genirq/
//    to see what actually owns an address.) If you want it gone, unbind it
//    at runtime: echo 40000000.fabric > \
//        /sys/bus/platform/drivers/uio_pdrv_genirq/unbind
//
// Needs `uio_pdrv_genirq.of_id=generic-uio` on the kernel command line and
// the u-dma-buf module loaded (see ../../Software/README.md).
//
// Compile:  dtc -@ -O dtb -o openjls.dtbo openjls.dtso

/dts-v1/;
/plugin/;

/ {
    fragment@0 {
        target-path = "/";
        __overlay__ {
            #address-cells = <1>;
            #size-cells = <1>;

            openjls@40000000 {
                compatible = "generic-uio";
                reg = <0x40000000 0x1000>;
            };

            dma@40400000 {
                compatible = "generic-uio";
                reg = <0x40400000 0x10000>;
                /* DMA IRQs are not wired to the PS in this design; the
                 * server polls. If you add them, uncomment and set the SPI
                 * numbers from the IRQ_F2P mapping (first fabric IRQ = 61,
                 * DT value = 61 - 32 = 29):
                 * interrupt-parent = <&intc>;
                 * interrupts = <0 29 4>;
                 */
            };

            /* Pixels in: 16 MiB fits the 4096x4096 @ 8-bit maximum. */
            udmabuf-ojls-tx {
                compatible = "ikwzm,u-dma-buf";
                device-name = "udmabuf-ojls-tx";
                size = <0x01000000>;
            };

            /* Bitstream out: raw size + 25% + slack, per the server's
             * worst-case check. */
            udmabuf-ojls-rx {
                compatible = "ikwzm,u-dma-buf";
                device-name = "udmabuf-ojls-rx";
                size = <0x01800000>;
            };
        };
    };
};
